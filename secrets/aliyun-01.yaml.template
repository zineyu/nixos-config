# 这是未加密的 secret 模板，仅作为示例。
#
# 流程：
# 1. 在 aliyun-01 上获取 age public key：
#      ssh-to-age -i /etc/ssh/ssh_host_ed25519_key.pub
# 2. 把该 key 填入 .sops.yaml 中 &aliyun-01 占位符并取消注释。
# 3. 复制本文件：
#      cp secrets/aliyun-01.yaml.template secrets/aliyun-01.yaml
# 4. 在 devShell 中加密编辑：
#      sops secrets/aliyun-01.yaml
# 5. 在 hosts/aliyun-01/configuration.nix 中取消 sops 相关注释。
#
# 注意：不要把本文件（.template）直接提交为未加密的 secrets/aliyun-01.yaml。

# 示例字段，按需替换为真实 secret。
example_secret: "replace-me-before-encrypting"
